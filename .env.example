# AURALINK environment variables.
# Copy this file to `.env` and fill in your own values. `.env` is gitignored,
# so your secrets stay out of the repo. Never commit a real token.
#
# Auto-loaded at startup if `python-dotenv` is installed (see requirements.txt).
# Otherwise, load it manually before running:
#   set -a; source .env; set +a

# Pulsoid access token for a live heart rate (--pulsoid), e.g. an Apple Watch.
# Create one at https://pulsoid.net/ui/keys with the data:heart_rate:read scope.
PULSOID_TOKEN=
